<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/background_dark">

    <!-- Header with app name and server -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp"
        android:paddingBottom="8dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/app_name"
            android:textSize="20sp"
            android:textStyle="bold"
            android:textColor="@color/text_primary"
            android:layout_marginBottom="4dp" />

        <EditText
            android:id="@+id/server_address"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:minHeight="40dp"
            android:padding="10dp"
            android:hint="@string/server_address_hint"
            android:textColorHint="@color/text_secondary"
            android:textColor="@color/text_primary"
            android:background="@drawable/input_field_bg"
            android:inputType="textUri"
            android:textSize="13sp" />
    </LinearLayout>

    <!-- Rich content area: weather, email previews, etc. (HTML, real-time updates) -->
    <FrameLayout
        android:id="@+id/rich_content_container"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/surface_dark"
        android:visibility="gone">

        <WebView
            android:id="@+id/rich_content_webview"
            android:layout_width="match_parent"
            android:layout_height="140dp"
            android:background="@color/surface_dark"
            android:scrollbars="vertical"
            android:padding="12dp" />
    </FrameLayout>

    <!-- Input area: homed above chat so it stays visible; new answers appear below -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp"
        android:background="@color/background_dark">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="8dp">

            <EditText
                android:id="@+id/prompt_input"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content"
                android:minLines="1"
                android:minHeight="44dp"
                android:padding="12dp"
                android:inputType="textMultiLine|textCapSentences"
                android:hint="@string/prompt_hint"
                android:textColorHint="@color/text_secondary"
                android:textColor="@color/text_primary"
                android:background="@drawable/input_field_bg"
                android:maxLines="4" />

            <ImageButton
                android:id="@+id/mic_btn"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:layout_marginStart="8dp"
                android:contentDescription="@string/mic_desc"
                android:src="@drawable/ic_mic"
                android:tint="@color/accent_blue"
                android:background="?attr/selectableItemBackgroundBorderless" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginBottom="8dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">
                <Switch
                    android:id="@+id/speak_switch"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/speak_responses"
                    android:textColor="@color/text_primary" />
                <Button
                    android:id="@+id/check_in_btn"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="16dp"
                    android:text="@string/check_in"
                    android:textAllCaps="false"
                    android:background="@drawable/btn_primary" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginTop="4dp">
                <Button
                    android:id="@+id/location_btn"
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="4dp"
                    android:text="@string/attach_location"
                    android:textAllCaps="false"
                    android:textSize="12sp"
                    android:background="@drawable/btn_primary" />
                <Button
                    android:id="@+id/camera_btn"
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="4dp"
                    android:layout_marginEnd="4dp"
                    android:text="@string/attach_camera"
                    android:textAllCaps="false"
                    android:textSize="12sp"
                    android:background="@drawable/btn_primary" />
                <Button
                    android:id="@+id/save_btn"
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="4dp"
                    android:text="@string/save_chat"
                    android:textAllCaps="false"
                    android:textSize="12sp"
                    android:background="@drawable/btn_primary" />
            </LinearLayout>
        </LinearLayout>

        <Button
            android:id="@+id/ask_btn"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:minHeight="48dp"
            android:text="@string/ask_ai"
            android:textColor="@color/white"
            android:textAllCaps="false"
            android:background="@drawable/btn_primary" />
    </LinearLayout>

    <!-- Chat messages (WebView with server CSS, full width, copy/paste); scroll to read -->
    <WebView
        android:id="@+id/chat_webview"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:background="@color/background_dark"
        android:scrollbars="vertical" />
</LinearLayout>
