<?xml version="1.0" encoding="utf-8"?>
<!-- ChatGPT/Grok-style: chat-first, input at bottom, minimal chrome -->
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
        android:id="@+id/root_layout"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:background="@color/background_dark">

    <!-- Compact header: Ember version + server dropdown + menu -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="8dp"
        android:paddingVertical="4dp"
        android:background="@color/surface_dark"
        android:minHeight="36dp">

        <TextView
            android:id="@+id/app_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/app_name"
            android:textSize="12sp"
            android:textStyle="bold"
            android:textColor="@color/text_primary"
            android:layout_marginEnd="8dp" />

        <Spinner
            android:id="@+id/server_spinner"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="28dp"
            android:minWidth="80dp"
            android:background="@drawable/input_field_bg"
            android:paddingHorizontal="6dp"
            android:spinnerMode="dropdown" />

        <ImageButton
            android:id="@+id/menu_btn"
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:layout_marginStart="4dp"
            android:contentDescription="Menu"
            android:src="@drawable/ic_more"
            android:tint="@color/text_primary"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:scaleType="centerInside" />
    </LinearLayout>

    <!-- Rich content: inline card with border, chicken placeholder when empty -->
    <FrameLayout
        android:id="@+id/rich_content_container"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/rich_content_border"
        android:padding="2dp"
        android:visibility="visible">

        <WebView
            android:id="@+id/rich_content_webview"
            android:layout_width="match_parent"
            android:layout_height="120dp"
            android:background="@android:color/transparent"
            android:scrollbars="vertical"
            android:padding="8dp" />
    </FrameLayout>

    <!-- Chat: main content, scrolls from bottom up, top fade for older messages -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <WebView
            android:id="@+id/chat_webview"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@color/background_dark"
            android:scrollbars="vertical" />

        <!-- Fade overlay: older messages fade as they scroll up (passes touches through) -->
        <View
            android:layout_width="match_parent"
            android:layout_height="64dp"
            android:layout_gravity="top"
            android:background="@drawable/chat_fade_top" />
    </FrameLayout>

    <!-- Error: minimal, above input -->
    <TextView
        android:id="@+id/error_text"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:visibility="gone"
        android:padding="8dp"
        android:textSize="12sp"
        android:textColor="@color/text_secondary"
        android:background="@color/surface_dark" />

    <!-- Input bar: fixed at bottom (ChatGPT/Grok style), compact buttons -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="10dp"
        android:paddingVertical="8dp"
        android:background="@color/surface_dark">

        <EditText
            android:id="@+id/prompt_input"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="wrap_content"
            android:minHeight="38dp"
            android:minLines="1"
            android:maxLines="4"
            android:paddingHorizontal="12dp"
            android:paddingVertical="8dp"
            android:inputType="textMultiLine|textCapSentences"
            android:hint="@string/prompt_hint"
            android:textColorHint="@color/text_secondary"
            android:textColor="@color/text_primary"
            android:background="@drawable/input_field_bg"
            android:textSize="15sp"
            android:layout_marginEnd="6dp" />

        <ImageButton
            android:id="@+id/speak_btn"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:layout_marginEnd="2dp"
            android:contentDescription="@string/speak_responses"
            android:src="@drawable/ic_face_speak"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:scaleType="centerInside" />

        <ImageButton
            android:id="@+id/mic_btn"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:layout_marginEnd="2dp"
            android:contentDescription="@string/mic_desc"
            android:src="@drawable/ic_mic"
            android:tint="@color/accent_blue"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:scaleType="centerInside" />

        <ImageButton
            android:id="@+id/ask_btn"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:contentDescription="@string/ask_ai"
            android:src="@drawable/ic_send"
            android:tint="@color/accent_blue"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:scaleType="centerInside" />
    </LinearLayout>
    </LinearLayout>

    <!-- Splash overlay: Promethos logo + EMBER ASSISTANT, fades on first server connection -->
    <include
        android:id="@+id/splash_include"
        layout="@layout/splash_overlay" />
</FrameLayout>
